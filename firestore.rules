rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── User data: only the authenticated user can read/write their own data ──
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // Kid profiles
      match /kids/{kidId} {
        allow read, write: if isOwner(uid);

        // Quiz results
        match /results/{resultId} {
          allow read, write: if isOwner(uid);
        }
      }
    }

    // ── Feedback: any signed-in user can submit; no one can read,
    //    edit, or delete via the client (reviewed via Console) ──
    match /feedback/{feedbackId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 4000;
      allow read, update, delete: if false;
    }

    // ── Deny everything else ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
